        private void button13_Click(object sender, EventArgs e)
        {
            //Btn-Igual

            string pantalla = display.Text;
            string[] valoresSeparados = pantalla.Split(' ');


            if ( (display.Text.Contains(" + ") || display.Text.Contains(" - ") || display.Text.Contains(" / ") || display.Text.Contains(" * ")) && !string.IsNullOrEmpty(valoresSeparados[2] || valoresSeparados[2] == ".") )
            {
                string signo = valoresSeparados[1];

                double Num1 = Convert.ToDouble(valoresSeparados[0]);
                double Num2 = Convert.ToDouble(valoresSeparados[2]);
                double total = 0;

                switch (signo)
                {
                    case "+":
                        total = Num1 + Num2;
                        display.Text = total.ToString();
                        break;

                    case "-":
                        total = Num1 - Num2;
                        display.Text = total.ToString();
                        break;

                    case "/":
                        total = Num1 / Num2;
                        display.Text = total.ToString();
                        break;

                    case "*":
                        total = Num1 * Num2;
                        display.Text = total.ToString();
                        break;
                }
            } else
            {
            }
        }

        private void btnLimpiarChar_Click(object sender, EventArgs e)
